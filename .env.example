DATABASE_URL=postgresql+asyncpg://opscore:opscore@localhost:5432/opscore
SECRET_KEY=change-me-in-production
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
PUBLIC_BASE_URL=http://localhost:8000
SEED_DEMO_DATA=true

# Vercel deployment (backend service environment variables):
# Without DATABASE_URL on Vercel, the app auto-uses SQLite in /tmp for demo deployments.
# For production, provision Postgres and set:
# DATABASE_URL=postgresql+asyncpg://USER:PASS@HOST/DB?sslmode=require
# SECRET_KEY=<strong-random-secret>
# CORS_ORIGINS=https://your-app.vercel.app
# PUBLIC_BASE_URL=https://your-app.vercel.app
# SEED_DEMO_DATA=true   # first deploy only; set false after demo users are seeded
